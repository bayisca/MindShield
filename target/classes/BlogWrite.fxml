<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="560.0" prefWidth="620.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mindshield.ui.BlogWriteController">
   <children>
      <VBox prefHeight="560.0" prefWidth="620.0" spacing="20.0">
         <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
         </padding>
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Button fx:id="btnCancel" mnemonicParsing="false" text="İptal Et" style="-fx-background-color: transparent; -fx-text-fill: #f44336;" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Text styleClass="title-text" style="-fx-font-size: 24;" text="Yeni Blog Yazısı" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Button fx:id="btnPublish" mnemonicParsing="false" style="-fx-background-color: #4CAF50;" text="Yayınla" />
               </children>
            </HBox>
            
            <Separator />
            
            <VBox spacing="10.0">
               <children>
                  <Label text="Başlık" style="-fx-font-weight: bold; -fx-font-size: 14;" />
                  <TextField fx:id="fldTitle" prefHeight="45.0" promptText="Yazınızın dikkat çekici bir başlığı olsun..." />
               </children>
            </VBox>
            
            <VBox spacing="10.0" VBox.vgrow="ALWAYS">
               <children>
                  <Label text="İçerik" style="-fx-font-weight: bold; -fx-font-size: 14;" />
                  <TextArea fx:id="fldContent" prefHeight="300.0" promptText="Bilgi ve deneyimlerinizi buraya yazın..." wrapText="true" style="-fx-font-size: 14;" />
               </children>
            </VBox>
            
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Label text="Yazar:" textFill="#666" />
                  <Label fx:id="lblAuthor" text="Anonim" style="-fx-font-weight: bold;" textFill="#1a237e" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
