<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="560.0" prefWidth="620.0" styleClass="main-container" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mindshield.ui.BlogDetailController">
   <children>
      <VBox prefHeight="560.0" prefWidth="620.0" spacing="20.0">
         <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
         </padding>
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Button fx:id="btnBack" mnemonicParsing="false" styleClass="btn-secondary" text="← Geri Dön" />
                  <Region HBox.hgrow="ALWAYS" />
                  <HBox fx:id="adminControls" spacing="10.0" visible="false">
                     <children>
                        <Button fx:id="btnEdit" mnemonicParsing="false" styleClass="btn-secondary" text="✎ Düzenle" />
                        <Button fx:id="btnDelete" mnemonicParsing="false" styleClass="button" style="-fx-background-color: -fx-danger;" text="🗑 Sil" />
                     </children>
                  </HBox>
               </children>
            </HBox>
            
            <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
               <content>
                  <VBox spacing="25.0" styleClass="card" style="-fx-padding: 30;">
                     <children>
                        <Text fx:id="txtTitle" styleClass="title-text" text="Blog Başlığı" />
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                           <children>
                              <Label styleClass="subtitle-text" text="Yazar:" />
                              <Label fx:id="lblAuthor" style="-fx-font-weight: bold; -fx-text-fill: -fx-primary;" text="Yazar Adı" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Label fx:id="lblDate" styleClass="subtitle-text" text="Tarih" />
                           </children>
                        </HBox>
                        <Separator />
                        <Text fx:id="txtContent" style="-fx-font-size: 15; -fx-line-spacing: 5;" text="Blog içeriği buraya gelecek..." wrappingWidth="520.0" />
                        
                        <Separator />
                        <VBox spacing="15.0">
                           <children>
                              <Text style="-fx-font-weight: bold; -fx-font-size: 18; -fx-fill: -fx-text-title;" text="Yorumlar" />
                              <VBox fx:id="commentContainer" spacing="12.0" />
                              <HBox spacing="10.0">
                                 <children>
                                    <TextField fx:id="commentInput" prefHeight="40.0" promptText="Bir yorum yaz..." HBox.hgrow="ALWAYS" />
                                    <Button mnemonicParsing="false" onAction="#addComment" prefHeight="40.0" text="Gönder" />
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                     </children>
                  </VBox>
               </content>
            </ScrollPane>
         </children>
      </VBox>
   </children>
</AnchorPane>
