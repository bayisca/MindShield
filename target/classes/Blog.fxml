<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="560.0" prefWidth="620.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mindshield.ui.BlogController">
   <children>
      <VBox prefHeight="560.0" prefWidth="620.0" spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <children>
            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <Text styleClass="title-text" style="-fx-font-size: 24;" text="Uzman Blogları" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Button fx:id="btnWrite" mnemonicParsing="false" style="-fx-background-color: #4CAF50;" text="+ Yeni Yazı Yaz" />
               </children>
            </HBox>
            
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
               <content>
                  <VBox fx:id="blogContainer" spacing="15.0">
                     <children>
                        <!-- Blog yazıları dinamik olarak eklenecek -->
                     </children>
                  </VBox>
               </content>
            </ScrollPane>
         </children>
      </VBox>
   </children>
</AnchorPane>