<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="450.0" prefWidth="700.0" styleClass="main-container" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mindshield.ui.LoginController">
   <children>
      <VBox alignment="CENTER" layoutX="225.0" layoutY="60.0" prefWidth="250.0" spacing="25.0">
         <children>
            <VBox alignment="CENTER" spacing="5.0">
               <children>
                  <Text styleClass="title-text" text="MindShield" />
                  <Text styleClass="subtitle-text" text="Güvenli ve Anonim Danışmanlık" />
               </children>
            </VBox>
            
            <VBox spacing="15.0">
               <children>
                  <TextField fx:id="personaField" prefHeight="40.0" promptText="Persona Adı" />
                  <PasswordField fx:id="passwordField" prefHeight="40.0" promptText="Şifre" />
               </children>
            </VBox>

            <Button maxWidth="Infinity" onAction="#handleLogin" prefHeight="45.0" text="Giriş Yap" />
            
            <Hyperlink onAction="#goToSignUp" styleClass="hyperlink" text="Hesabınız yok mu? Persona oluşturun" />
         </children>
      </VBox>
   </children>
</AnchorPane>