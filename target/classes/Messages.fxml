<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="560.0" prefWidth="660.0" styleClass="main-container" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mindshield.ui.MessagesController">
   <children>
      <HBox prefHeight="560.0" prefWidth="660.0">
         <children>
            <!-- Contacts Sidebar -->
            <VBox prefWidth="200.0" spacing="10.0" styleClass="card" style="-fx-background-radius: 0;">
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
               <children>
                  <Label style="-fx-font-weight: bold; -fx-font-size: 14;" text="Konuşmalar" />
                  <ListView fx:id="contactList" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: transparent;" />
               </children>
            </VBox>
            
            <!-- Chat Area -->
            <VBox HBox.hgrow="ALWAYS" spacing="15.0">
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="10.0">
                     <children>
                        <Label fx:id="lblSelectedContact" style="-fx-font-weight: bold; -fx-font-size: 18;" text="Bir kişi seçin" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label text="Güvenli Bağlantı" textFill="#4caf50" style="-fx-font-size: 12;" />
                     </children>
                  </HBox>
                  
                  <Separator />
                  
                  <VBox styleClass="card" VBox.vgrow="ALWAYS" style="-fx-padding: 10;">
                     <children>
                        <TextArea fx:id="chatArea" editable="false" prefHeight="400.0" style="-fx-background-color: transparent; -fx-control-inner-background: white; -fx-background-radius: 8;" wrapText="true" VBox.vgrow="ALWAYS" />
                     </children>
                  </VBox>
                  
                  <HBox spacing="10.0">
                     <children>
                        <TextField fx:id="messageInput" prefHeight="45.0" promptText="Mesajınızı yazın..." HBox.hgrow="ALWAYS" />
                        <Button onAction="#sendMessage" prefHeight="45.0" prefWidth="100.0" text="Gönder" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</AnchorPane>