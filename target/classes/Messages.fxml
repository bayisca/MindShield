<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="560.0" prefWidth="620.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mindshield.ui.MessagesController">
   <children>
      <VBox prefHeight="560.0" prefWidth="620.0" spacing="15.0">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         <children>
            <Text styleClass="title-text" style="-fx-font-size: 24;" text="Mesajlaşma" />
            
            <VBox styleClass="card" VBox.vgrow="ALWAYS">
               <children>
                  <TextArea fx:id="chatArea" editable="false" prefHeight="400.0" style="-fx-background-color: transparent; -fx-control-inner-background: white; -fx-background-radius: 10;" wrapText="true" />
               </children>
            </VBox>
            
            <HBox spacing="10.0">
               <children>
                  <TextField fx:id="messageInput" prefHeight="40.0" promptText="Mesajınızı güvenle yazın..." HBox.hgrow="ALWAYS" />
                  <Button onAction="#sendMessage" prefHeight="40.0" text="Gönder" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>