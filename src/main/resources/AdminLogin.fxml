<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="520.0" prefWidth="440.0" styleClass="main-container,welcome-root"
            stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mindshield.ui.AdminLoginController">
   <children>
      <VBox alignment="CENTER" spacing="20.0"
            AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
            AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0"
            style="-fx-background-color: #F3E3D0; -fx-padding: 48;">
         <children>
            <Label text="Yönetici Girişi"
                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #34495E;" />
            <Label text="Şikayetleri ve moderasyonu buradan yönetirsiniz."
                   wrapText="true" maxWidth="360"
                   style="-fx-font-size: 13px; -fx-text-fill: #6A7C8F;" />

            <VBox maxWidth="340.0" spacing="10.0">
               <children>
                  <Label text="YÖNETİCİ PERSONA ADI"
                         style="-fx-font-size: 11px; -fx-text-fill: #6A7C8F;" />
                  <TextField fx:id="personaField" prefHeight="44.0" promptText="Örn. admin" />
                  <Label text="ŞİFRE"
                         style="-fx-font-size: 11px; -fx-text-fill: #6A7C8F;" />
                  <PasswordField fx:id="passwordField" prefHeight="44.0" promptText="Şifre" />
                  <Region prefHeight="8.0" />
                  <Button maxWidth="Infinity" prefHeight="46.0" onAction="#handleLogin" text="Yönetici olarak gir" />
                  <HBox alignment="CENTER" spacing="8.0">
                     <children>
                        <Hyperlink onAction="#goUserLogin" text="Danışan / danışman girişine dön" />
                     </children>
                  </HBox>
                  <Label fx:id="lblError" wrapText="true" maxWidth="340"
                         style="-fx-text-fill: #E09B9B; -fx-font-size: 12px;" />
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
