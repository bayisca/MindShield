<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" styleClass="main-container" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mindshield.ui.DashboardController">
   <children>
      <HBox prefHeight="600.0" prefWidth="900.0">
         <children>
            <!-- Sidebar -->
            <VBox prefHeight="600.0" prefWidth="240.0" spacing="10.0" styleClass="sidebar">
               <padding>
                  <Insets top="30.0" />
               </padding>
               <children>
                  <VBox alignment="CENTER" spacing="10.0">
                     <children>
                        <Text styleClass="title-text" style="-fx-font-size: 20;" text="MindShield" />
                     </children>
                     <VBox.margin>
                        <Insets bottom="30.0" />
                     </VBox.margin>
                  </VBox>
                  
                  <Button maxWidth="Infinity" onAction="#showBlog" styleClass="side-button" text="📑 Uzman Blogları" />
                  <Button maxWidth="Infinity" onAction="#showMessages" styleClass="side-button" text="💬 Mesajlarım" />
                  <Button maxWidth="Infinity" onAction="#showMeditation" styleClass="side-button" text="🎧 SoulShield" />
                  <Button fx:id="btnJourShield" maxWidth="Infinity" onAction="#showJourShield" styleClass="side-button" text="🔒 JourShield" />
                  <Button maxWidth="Infinity" onAction="#showProfile" styleClass="side-button" text="👤 Profil ve Ayarlar" />
                  
                  <Region VBox.vgrow="ALWAYS" />
                  
                  <Button maxWidth="Infinity" onAction="#handleLogout" styleClass="side-button" text="🚪 Çıkış Yap" />
               </children>
            </VBox>
            
            <!-- Content Area -->
            <StackPane fx:id="contentArea" prefHeight="600.0" prefWidth="660.0">
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
            </StackPane>
         </children>
      </HBox>
   </children>
</AnchorPane>