<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0" styleClass="main-container" stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mindshield.ui.DashboardController">
   <children>
      <HBox prefHeight="700.0" prefWidth="1000.0"
            AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
            AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>

            <!-- SIDEBAR -->
            <VBox prefWidth="240.0" styleClass="sidebar" spacing="4.0">
               <padding><Insets top="30.0" bottom="20.0" left="12.0" right="12.0" /></padding>
               <children>

                  <!-- Brand: plain text, no emoji -->
                  <VBox alignment="CENTER" spacing="4.0">
                     <padding><Insets bottom="28.0" /></padding>
                     <children>
                        <ImageView fitHeight="60.0" fitWidth="60.0" preserveRatio="true" pickOnBounds="true">
                           <image>
                              <Image url="@logos/logo.png" />
                           </image>
                        </ImageView>
                        <Label text="MindShield"
                               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #81A6C6;" />
                        <Label text="Guvenli &amp; Anonim Danismanlik"
                               style="-fx-font-size: 10px; -fx-text-fill: #8A9CAE;" />
                     </children>
                  </VBox>

                  <Button fx:id="btnNavHome" maxWidth="Infinity" onAction="#showHome"
                          styleClass="side-button" text="Ana Sayfa">
                      <graphic>
                          <Label text="🏠" style="-fx-font-size: 18px;" />
                      </graphic>
                  </Button>

                  <Button fx:id="btnNavBlog" maxWidth="Infinity" onAction="#showBlog"
                          styleClass="side-button" text="Uzman Bloglari">
                      <graphic>
                          <Label text="📑" style="-fx-font-size: 18px;" />
                      </graphic>
                  </Button>

                  <Button fx:id="btnNavForum" maxWidth="Infinity" onAction="#showForum"
                          styleClass="side-button" text="Forum">
                      <graphic>
                          <Label text="🤝" style="-fx-font-size: 18px;" />
                      </graphic>
                  </Button>

                  <Button fx:id="btnNavMessages" maxWidth="Infinity" onAction="#showMessages"
                          styleClass="side-button" text="Mesajlarim">
                      <graphic>
                          <Label text="💬" style="-fx-font-size: 18px;" />
                      </graphic>
                  </Button>

                  <Button fx:id="btnNavCounselors" maxWidth="Infinity" onAction="#showCounselors"
                          styleClass="side-button" text="Danismanlarim">
                      <graphic>
                          <Label text="👥" style="-fx-font-size: 18px;" />
                      </graphic>
                  </Button>

                  <Button maxWidth="Infinity" onAction="#showMeditation"
                          styleClass="side-button" text="SoulShield - Meditasyon">
                      <graphic>
                          <Label text="🎧" style="-fx-font-size: 18px;" />
                      </graphic>
                  </Button>

                  <Button fx:id="btnJourShield" maxWidth="Infinity" onAction="#showJourShield"
                          styleClass="side-button" text="Gunluk (JourShield)">
                      <graphic>
                          <Label text="🔒" style="-fx-font-size: 18px;" />
                      </graphic>
                  </Button>

                  <Region VBox.vgrow="ALWAYS" />

                  <!-- User badge -->
                  <VBox fx:id="userBadge" styleClass="card"
                        style="-fx-padding: 12 14; -fx-background-radius: 10; -fx-border-radius: 10;"
                        spacing="2.0">
                     <padding><Insets bottom="10.0" /></padding>
                     <children>
                        <Label fx:id="lblUserName"
                               style="-fx-font-weight: bold; -fx-font-size: 13; -fx-text-fill: #34495E;"
                               text="Persona" />
                        <Label fx:id="lblUserRole"
                               style="-fx-font-size: 11; -fx-text-fill: #81A6C6;"
                               text="Rol" />
                     </children>
                  </VBox>

                  <Button maxWidth="Infinity" onAction="#handleLogout"
                          styleClass="side-button-logout" text="Cikis Yap" />
               </children>
            </VBox>

            <!-- CONTENT AREA -->
            <StackPane fx:id="contentArea" HBox.hgrow="ALWAYS"
                       style="-fx-background-color: #F3E3D0;">
               <padding><Insets bottom="24.0" left="24.0" right="24.0" top="24.0" /></padding>
            </StackPane>

         </children>
      </HBox>
   </children>
</AnchorPane>