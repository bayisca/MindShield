<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="620.0" prefWidth="700.0" styleClass="main-container"
            stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mindshield.ui.SettingsController">
   <children>
      <ScrollPane fitToWidth="true" styleClass="scroll-pane"
                  AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                  AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <content>
            <VBox spacing="22.0">
               <padding><Insets bottom="30.0" left="4.0" right="4.0" top="4.0" /></padding>
               <children>

                  <!-- Header -->
                  <Label text="⚙️  Profil ve Ayarlar"
                         style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #34495E;" />

                  <!-- Counselor özet -->
                  <VBox fx:id="counselorSummarySection" spacing="10.0" styleClass="card" style="-fx-padding: 24;"
                        visible="false" managed="false">
                     <children>
                        <Label text="Hesap özeti"
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;" />
                        <Label fx:id="lblJoinedDate" style="-fx-text-fill: #4A5B6C; -fx-font-size: 13px;" />
                        <Label fx:id="lblExpertiseTitle" style="-fx-text-fill: #81A6C6; -fx-font-size: 13px;" />
                        <Label fx:id="lblBlogPostCount" style="-fx-text-fill: #4A5B6C; -fx-font-size: 13px;" />
                        <Label fx:id="lblForumCount" style="-fx-text-fill: #4A5B6C; -fx-font-size: 13px;" />
                        <Label fx:id="lblHelpedClientsCount" style="-fx-text-fill: #4A5B6C; -fx-font-size: 13px;" />
                     </children>
                  </VBox>

                  <!-- Danışan özeti -->
                  <VBox fx:id="clientSummarySection" spacing="10.0" styleClass="card" style="-fx-padding: 24;"
                        visible="false" managed="false">
                     <children>
                        <Label text="Profil özeti"
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;" />
                        <Label fx:id="lblClientJoinedDate" style="-fx-text-fill: #4A5B6C; -fx-font-size: 13px;" />
                        <Label fx:id="lblClientForumCount" style="-fx-text-fill: #4A5B6C; -fx-font-size: 13px;" />
                     </children>
                  </VBox>

                  <!-- Persona settings card -->
                  <VBox spacing="16.0" styleClass="card" style="-fx-padding: 24;">
                     <children>
                        <Label text="Persona Bilgileri"
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;" />

                        <VBox spacing="6.0">
                           <children>
                              <Label text="YENİ PERSONA ADI"
                                     style="-fx-font-size: 11px; -fx-text-fill: #6A7C8F;" />
                              <TextField fx:id="newPersonaName" prefHeight="42.0"
                                         promptText="Yeni adını gir" maxWidth="Infinity" />
                           </children>
                        </VBox>

                        <VBox spacing="6.0">
                           <children>
                              <Label text="YENİ ŞİFRE"
                                     style="-fx-font-size: 11px; -fx-text-fill: #6A7C8F;" />
                              <PasswordField fx:id="newPassword" prefHeight="42.0"
                                             promptText="Yeni şifreni gir" maxWidth="Infinity" />
                           </children>
                        </VBox>

                        <Button onAction="#saveSettings" prefHeight="42.0"
                                text="Değişiklikleri Kaydet" />
                     </children>
                  </VBox>

                  <!-- My Blog Posts (counselor) -->
                  <VBox fx:id="myPostsSection" spacing="14.0" styleClass="card" style="-fx-padding: 24;">
                     <children>
                        <Label text="📑  Blog Yazılarım"
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;" />
                        <VBox fx:id="myPostsContainer" spacing="10.0">
                           <!-- Java tarafından doldurulacak -->
                        </VBox>
                     </children>
                  </VBox>



                  <!-- Danger zone -->
                  <VBox spacing="14.0" styleClass="card"
                        style="-fx-padding: 24; -fx-border-color: rgba(226,149,149,0.3); -fx-border-radius: 14;">
                     <children>
                        <Label text="🥺 Lütfen bizi bırakma!"
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #E09B9B;" />
                        <Label text="Bu işlemler geri alınamaz. Dikkatli ol."
                               style="-fx-font-size: 12px; -fx-text-fill: #8A9CAE;" />
                        <Button onAction="#deleteAccount" text="Hesabımı Sil" styleClass="btn-danger"
                                prefHeight="40.0" prefWidth="200.0" />
                     </children>
                  </VBox>

               </children>
            </VBox>
         </content>
      </ScrollPane>
   </children>
</AnchorPane>