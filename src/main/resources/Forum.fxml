<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="620.0" prefWidth="980.0" styleClass="main-container" stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mindshield.ui.ForumController">
   <children>
      <StackPane fx:id="forumStack" AnchorPane.topAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0">
         <children>
            <VBox fx:id="categoriesView" spacing="16.0">
               <padding><Insets top="22.0" right="28.0" bottom="22.0" left="28.0"/></padding>
               <children>
                  <VBox spacing="4.0">
                     <children>
                        <Label text="Forum Kategorileri" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #34495E;"/>
                        <Label text="Konular uzmanlik alanlarina gore ayrildi. Devam etmek icin bir kategori sec."
                               style="-fx-font-size: 13px; -fx-text-fill: #8A9CAE;"/>
                     </children>
                  </VBox>
                  <ListView fx:id="categoryList" VBox.vgrow="ALWAYS"/>
               </children>
            </VBox>

            <VBox fx:id="topicsView" spacing="16.0" visible="false" managed="false">
               <padding><Insets top="22.0" right="28.0" bottom="22.0" left="28.0"/></padding>
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="12.0">
                     <children>
                        <Button text="Geri" onAction="#backToCategories" styleClass="btn-secondary"/>
                        <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label fx:id="topicPageTitle" text="Kategori"
                                     style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #34495E;"/>
                              <Label fx:id="topicPageDescription" text=""
                                     style="-fx-font-size: 12px; -fx-text-fill: #8A9CAE;" wrapText="true"/>
                           </children>
                        </VBox>
                        <TextField fx:id="topicSearchField" prefWidth="260.0" promptText="Baslik ara..."/>
                        <Button text="Konu Olustur" onAction="#showCreateTopicPage"/>
                     </children>
                  </HBox>
                  <ListView fx:id="topicList" VBox.vgrow="ALWAYS"/>
               </children>
            </VBox>

            <VBox fx:id="createTopicView" spacing="16.0" visible="false" managed="false">
               <padding><Insets top="22.0" right="28.0" bottom="22.0" left="28.0"/></padding>
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="12.0">
                     <children>
                        <Button text="Geri" onAction="#backToTopics" styleClass="btn-secondary"/>
                        <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label text="Yeni Konu Olustur"
                                     style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #34495E;"/>
                              <Label fx:id="createCategoryLabel" text=""
                                     style="-fx-font-size: 12px; -fx-text-fill: #658AAB;"/>
                           </children>
                        </VBox>
                     </children>
                  </HBox>

                  <VBox spacing="12.0" styleClass="card" style="-fx-padding: 22;" VBox.vgrow="ALWAYS">
                     <children>
                        <Label text="Baslik" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #6A7C8F;"/>
                        <TextField fx:id="topicTitleField" promptText="Konu basligi"/>
                        <Label text="Icerik" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #6A7C8F;"/>
                        <TextArea fx:id="topicBodyField" promptText="Konuyu acikla, deneyimini veya sorunu yaz..." wrapText="true" VBox.vgrow="ALWAYS"/>
                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                           <children>
                              <Button text="Vazgec" onAction="#backToTopics" styleClass="btn-secondary"/>
                              <Button text="Paylas" onAction="#createTopic"/>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </VBox>

            <VBox fx:id="topicDetailView" spacing="14.0" visible="false" managed="false">
               <padding><Insets top="22.0" right="28.0" bottom="22.0" left="28.0"/></padding>
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="12.0">
                     <children>
                        <Button text="Geri" onAction="#backToTopics" styleClass="btn-secondary"/>
                        <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label fx:id="detailTitle" text="Baslik"
                                     style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #34495E;" wrapText="true"/>
                              <Label fx:id="detailMeta" text=""
                                     style="-fx-font-size: 11px; -fx-text-fill: #8A9CAE;"/>
                           </children>
                        </VBox>
                        <Button fx:id="btnDeleteTopic" text="Sil" onAction="#deleteSelectedTopic" styleClass="btn-danger" visible="false" managed="false"/>
                     </children>
                  </HBox>

                  <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane">
                     <content>
                        <VBox fx:id="repliesContainer" spacing="10.0" style="-fx-padding: 2 2 2 2;"/>
                     </content>
                  </ScrollPane>

                  <VBox spacing="8.0" styleClass="card" style="-fx-padding: 14;">
                     <children>
                        <TextArea fx:id="replyBodyField" promptText="Bu konuya yanit yaz..." prefHeight="84.0" wrapText="true"/>
                        <HBox alignment="CENTER_RIGHT">
                           <children>
                              <Button text="Yanit Gonder" onAction="#sendReply"/>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </VBox>
         </children>
      </StackPane>
   </children>
</AnchorPane>
