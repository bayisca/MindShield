<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<AnchorPane prefHeight="620.0" prefWidth="820.0" styleClass="main-container,welcome-root"
            stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mindshield.ui.LoginController">
   <children>
      <HBox prefHeight="620.0" prefWidth="820.0"
            AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
            AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>

            <!-- LEFT: Branding panel -->
            <VBox prefWidth="400.0" alignment="CENTER" spacing="50.0"
                  style="-fx-background-color: linear-gradient(to bottom, #EAE0D2, #D2C4B4); -fx-padding: 50 50;">
               <children>
                  <ImageView fitHeight="120.0" fitWidth="120.0" preserveRatio="true" pickOnBounds="true">
                     <image>
                        <Image url="@logos/logo.png" />
                     </image>
                  </ImageView>

                  <TextFlow fx:id="textFlowBrand" textAlignment="CENTER"
                            style="-fx-effect: dropshadow(gaussian, rgba(20,184,166,0.5), 20, 0, 0, 0);">
                     <Text fx:id="textMind" style="-fx-font-size: 38px; -fx-font-weight: bold; -fx-fill: #81A6C6;" />
                     <Text fx:id="textShield" style="-fx-font-size: 38px; -fx-font-weight: bold; -fx-fill: #14B8A6;" />
                  </TextFlow>

                  <VBox spacing="8.0" alignment="CENTER">
                     <children>
                        <Label text="Guvenli &amp; Anonim Danismanlik"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #34495E;" />
                        <Label text="&quot;Kimligini degil, duygularini paylas.&quot;"
                               style="-fx-font-size: 16px; -fx-text-fill: #8A9CAE;"
                               wrapText="true" textAlignment="CENTER" alignment="CENTER" maxWidth="500.0"/>
                     </children>
                  </VBox>

                  <!-- Feature list -->
                  <VBox spacing="12.0" style="-fx-padding: 60 0 0 0;">
                     <children>
                        <HBox spacing="14.0" alignment="CENTER_LEFT" styleClass="welcome-feature-card">
                           <children>
                              <ImageView fitHeight="28.0" fitWidth="28.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@logos/personal-security_18254941.png" />
                                 </image>
                              </ImageView>
                              <VBox spacing="3.0">
                                 <children>
                                    <Label text="Tam Anonimlik" styleClass="welcome-feature-label" />
                                    <Label text="Gercek kimligin asla paylaşılmaz." styleClass="welcome-feature-desc" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                        <HBox spacing="14.0" alignment="CENTER_LEFT" styleClass="welcome-feature-card">
                           <children>
                              <ImageView fitHeight="28.0" fitWidth="28.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@logos/certificate_7231488.png" />
                                 </image>
                              </ImageView>
                              <VBox spacing="3.0">
                                 <children>
                                    <Label text="Uzman Danismanlar" styleClass="welcome-feature-label" />
                                    <Label text="Ruh sagligi profesyonelleri senin için burada." styleClass="welcome-feature-desc" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                        <HBox spacing="14.0" alignment="CENTER_LEFT" styleClass="welcome-feature-card">
                           <children>
                              <Label text="💬" styleClass="welcome-feature-icon-small" />
                              <VBox spacing="3.0">
                                 <children>
                                    <Label text="Forum Destegi" styleClass="welcome-feature-label" />
                                    <Label text="Ortak gruplarda yasadiginiz sorunlari digerleriyle paylasip destek alabilirsiniz." styleClass="welcome-feature-desc" wrapText="true" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                        <HBox spacing="14.0" alignment="CENTER_LEFT" styleClass="welcome-feature-card">
                           <children>
                              <Label text="🎵" styleClass="welcome-feature-icon-small" />
                              <VBox spacing="3.0">
                                 <children>
                                    <Label text="SoulShield" styleClass="welcome-feature-label" />
                                    <Label text="Zihninizi dinlendiren melodiler keşfedebilirsiniz." styleClass="welcome-feature-desc" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                        <HBox spacing="14.0" alignment="CENTER_LEFT" styleClass="welcome-feature-card">
                           <children>
                              <Label text="✍" styleClass="welcome-feature-icon-small" />
                              <VBox spacing="3.0">
                                 <children>
                                    <Label text="JourShield" styleClass="welcome-feature-label" />
                                    <Label text="JourShield ile dusuncelerinizi gunluge yazabilir, ruh halinizi takip edebilirsiniz. "
                                           styleClass="welcome-feature-desc" wrapText="true" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </VBox>

            <!-- RIGHT: Login form -->
            <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #F3E3D0; -fx-padding: 60 70;">
               <children>
                  <VBox maxWidth="340.0" spacing="0.0">
                     <children>
                        <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #34495E; -fx-padding: 0 0 6 0;" text="Hos Geldin" />
                        <Label style="-fx-font-size: 13px; -fx-text-fill: #8A9CAE; -fx-padding: 0 0 32 0;" text="Personanla giris yap" />

                        <Label style="-fx-font-size: 12px; -fx-text-fill: #6A7C8F; -fx-padding: 0 0 6 0;" text="PERSONA ADI" />
                        <TextField fx:id="personaField" prefHeight="46.0" promptText="Persona adini gir" maxWidth="Infinity" />
                        <Region prefHeight="16.0" />

                        <Label style="-fx-font-size: 12px; -fx-text-fill: #6A7C8F; -fx-padding: 0 0 6 0;" text="SIFRE" />
                        <PasswordField fx:id="passwordField" prefHeight="46.0" promptText="Sifreni gir" maxWidth="Infinity" />
                        <Region prefHeight="28.0" />

                        <Button maxWidth="Infinity" prefHeight="48.0" onAction="#handleLogin" text="Giris Yap" />

                        <HBox alignment="CENTER" style="-fx-padding: 20 0 0 0;" spacing="6.0">
                           <children>
                              <Label style="-fx-text-fill: #8A9CAE; -fx-font-size: 13px;" text="Henuz bir personan yok mu?" />
                              <Hyperlink onAction="#goToSignUp" text="Olustur" />
                           </children>
                        </HBox>

                        <Button maxWidth="Infinity" prefHeight="40.0" onAction="#openAdminLogin"
                                styleClass="btn-secondary" text="Yonetici girisi" />

                        <Label fx:id="lblError"
                               style="-fx-text-fill: #E09B9B; -fx-font-size: 12px; -fx-padding: 8 0 0 0;"
                               text="" wrapText="true" maxWidth="340.0" />
                     </children>
                  </VBox>
               </children>
            </VBox>

         </children>
      </HBox>
   </children>
</AnchorPane>
