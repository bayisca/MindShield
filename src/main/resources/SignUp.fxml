<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="500.0" prefWidth="400.0" styleClass="main-container" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mindshield.ui.SignUpController">
   <children>
      <VBox alignment="CENTER" layoutX="75.0" layoutY="50.0" prefWidth="250.0" spacing="25.0">
         <children>
            <VBox alignment="CENTER" spacing="5.0">
               <children>
                  <Text styleClass="title-text" text="Yeni Persona" />
                  <Text styleClass="subtitle-text" text="Anonim dünyana hoş geldin" />
               </children>
            </VBox>
            
            <VBox spacing="15.0">
               <children>
                  <TextField fx:id="regUser" prefHeight="40.0" promptText="Persona Adı" />
                  <PasswordField fx:id="regPass" prefHeight="40.0" promptText="Şifre" />
               </children>
            </VBox>

            <VBox spacing="10.0">
               <children>
                  <Label style="-fx-font-weight: bold;" text="Hesap Türü Seçin:" textFill="#444" />
                  <RadioButton fx:id="rbClient" selected="true" text="Danışan (Anonim)">
                     <toggleGroup><ToggleGroup fx:id="roleGroup" /></toggleGroup>
                  </RadioButton>
                  <RadioButton fx:id="rbCounselor" text="Danışman (Uzman)" toggleGroup="$roleGroup" />
               </children>
            </VBox>

            <Button maxWidth="Infinity" onAction="#handleSignUp" prefHeight="45.0" text="Kayıt Ol" />
            
            <Hyperlink onAction="#goToLogin" styleClass="hyperlink" text="Zaten bir Personam var" />
         </children>
      </VBox>
   </children>
</AnchorPane>