<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<AnchorPane prefHeight="660.0" prefWidth="820.0" styleClass="main-container,welcome-root"
            stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mindshield.ui.SignUpController">
   <children>
      <GridPane prefHeight="660.0" prefWidth="820.0"
            AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
            AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <columnConstraints>
            <ColumnConstraints percentWidth="40.0" />
            <ColumnConstraints percentWidth="60.0" />
         </columnConstraints>
         <rowConstraints>
            <RowConstraints vgrow="ALWAYS" />
         </rowConstraints>
         <children>

            <!-- LEFT: Branding -->
            <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" alignment="CENTER" spacing="20.0"
                  style="-fx-background-color: linear-gradient(to bottom, #EAE0D2, #D2C4B4); -fx-padding: 60 48;">
               <children>
                  <ImageView fitHeight="160.0" fitWidth="160.0" preserveRatio="true" pickOnBounds="true">
                     <image>
                        <Image url="@logos/logo.png" />
                     </image>
                  </ImageView>
                  <TextFlow textAlignment="CENTER"
                            style="-fx-effect: dropshadow(gaussian, rgba(20,184,166,0.5), 8, 0, 0, 0);">
                     <Text text="Mind" style="-fx-font-size: 38px; -fx-font-weight: bold; -fx-fill: #81A6C6;" />
                     <Text text="Shield" style="-fx-font-size: 38px; -fx-font-weight: bold; -fx-fill: #14B8A6;" />
                  </TextFlow>

                  <VBox spacing="8.0" alignment="CENTER">
                     <children>
                        <Label text="Yeni Persona Olustur"
                               style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #34495E;" />
                        <Label text="Gercek kimligin gizli kalirken yardim alabilirsin."
                               style="-fx-font-size: 12px; -fx-text-fill: #8A9CAE;"
                               wrapText="true" textAlignment="CENTER" maxWidth="260.0"/>
                     </children>
                  </VBox>

                  <VBox spacing="10.0" style="-fx-padding: 16 0 0 0;">
                     <children>
                        <HBox spacing="14.0" alignment="CENTER_LEFT" styleClass="welcome-feature-card">
                           <children>
                              <VBox spacing="2.0">
                                 <children>
                                    <Label text="Danisan Hesabi" styleClass="welcome-feature-label" />
                                    <Label text="Danismanlarla anonim gorusme yap, meditasyon ve gunluk tut."
                                           styleClass="welcome-feature-desc" wrapText="true" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                        <HBox spacing="14.0" alignment="CENTER_LEFT" styleClass="welcome-feature-card">
                           <children>
                              <VBox spacing="2.0">
                                 <children>
                                    <Label text="Danisмаn Hesabi" styleClass="welcome-feature-label" />
                                    <Label text="Blog yaz, danisan sorularini yanitla, destek sun."
                                           styleClass="welcome-feature-desc" wrapText="true" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
               <VBox.margin>
                  <Insets bottom="30.0" />
               </VBox.margin>
            </VBox>

            <!-- RIGHT: Register form -->
            <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" alignment="CENTER"
                  style="-fx-background-color: #F3E3D0; -fx-padding: 60 64;">
               <children>
                  <VBox maxWidth="320.0" spacing="0.0">
                     <children>
                        <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #34495E; -fx-padding: 0 0 4 0;" text="Kayit Ol" />
                        <Label style="-fx-font-size: 13px; -fx-text-fill: #8A9CAE; -fx-padding: 0 0 28 0;" text="Anonim dunyaya hos geldin" />

                        <Label style="-fx-font-size: 11px; -fx-text-fill: #6A7C8F; -fx-padding: 0 0 5 0;" text="PERSONA ADI" />
                        <TextField fx:id="regUser" prefHeight="44.0" promptText="Benzersiz bir takma ad sec" maxWidth="Infinity" />
                        <Region prefHeight="14.0" />

                        <Label style="-fx-font-size: 11px; -fx-text-fill: #6A7C8F; -fx-padding: 0 0 5 0;" text="SIFRE" />
                        <PasswordField fx:id="regPass" prefHeight="44.0" promptText="Guclu bir sifre belirle" maxWidth="Infinity" />
                        <Region prefHeight="20.0" />

                        <Label style="-fx-font-size: 11px; -fx-text-fill: #6A7C8F; -fx-padding: 0 0 10 0;" text="HESAP TURU" />
                        <HBox spacing="12.0">
                           <children>
                              <VBox styleClass="card" spacing="6.0"
                                    style="-fx-padding: 14 16; -fx-cursor: hand; -fx-background-radius: 10; -fx-border-radius: 10;"
                                    HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label text="Danisan" style="-fx-font-weight: bold; -fx-text-fill: #34495E; -fx-font-size: 13;" />
                                    <Label text="Destek almak istiyorum" style="-fx-font-size: 11; -fx-text-fill: #8A9CAE;" />
                                    <RadioButton fx:id="rbClient" selected="true" text="Sec">
                                       <toggleGroup><ToggleGroup fx:id="roleGroup" /></toggleGroup>
                                    </RadioButton>
                                 </children>
                              </VBox>
                              <VBox styleClass="card" spacing="6.0"
                                    style="-fx-padding: 14 16; -fx-cursor: hand; -fx-background-radius: 10; -fx-border-radius: 10;"
                                    HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label text="Danisman" style="-fx-font-weight: bold; -fx-text-fill: #34495E; -fx-font-size: 13;" />
                                    <Label text="Destek vermek istiyorum" style="-fx-font-size: 11; -fx-text-fill: #8A9CAE;" />
                                    <RadioButton fx:id="rbCounselor" text="Sec" toggleGroup="$roleGroup" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>

                        <VBox fx:id="expertiseBox" spacing="8.0" visible="false" managed="false">
                           <children>
                              <Region prefHeight="12.0" />
                              <Label style="-fx-font-size: 11px; -fx-text-fill: #6A7C8F;"
                                     text="UZMANLIK ALANI (destek gruplariyla uyumlu)" />
                              <ComboBox fx:id="expertiseCombo" prefHeight="40.0" maxWidth="Infinity"
                                        promptText="Uzmanlik secin" />
                           </children>
                        </VBox>

                        <Region prefHeight="24.0" />

                        <Button maxWidth="Infinity" prefHeight="46.0" onAction="#handleSignUp" text="Persona Olustur" />

                        <HBox alignment="CENTER" style="-fx-padding: 18 0 0 0;" spacing="6.0">
                           <children>
                              <Label style="-fx-text-fill: #8A9CAE; -fx-font-size: 13px;" text="Zaten bir personan var mi?" />
                              <Hyperlink onAction="#goToLogin" text="Giris Yap" />
                           </children>
                        </HBox>

                        <Label fx:id="lblError"
                               style="-fx-text-fill: #E09B9B; -fx-font-size: 12px; -fx-padding: 8 0 0 0;"
                               text="" wrapText="true" maxWidth="320.0" />
                     </children>
                  </VBox>
               </children>
            </VBox>

         </children>
      </GridPane>
   </children>
</AnchorPane>