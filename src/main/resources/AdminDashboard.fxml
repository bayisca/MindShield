<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="640.0" prefWidth="920.0" styleClass="main-container" stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mindshield.ui.AdminDashboardController">
   <children>
      <HBox prefHeight="640.0" prefWidth="920.0"
            AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
            AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <VBox prefWidth="260.0" styleClass="sidebar" spacing="8.0">
               <padding><Insets top="28.0" bottom="20.0" left="14.0" right="14.0" /></padding>
               <children>
                  <Label text="MindShield"
                         style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #E09B9B;" />
                  <Label text="Yönetici Paneli"
                         style="-fx-font-size: 11px; -fx-text-fill: #6A7C8F;" />
                  <Separator />
                  <Label fx:id="lblAdminName"
                         style="-fx-font-size: 13px; -fx-text-fill: #34495E;" />
                  <Region VBox.vgrow="ALWAYS" />
                  <Button maxWidth="Infinity" onAction="#handleLogout" styleClass="side-button-logout" text="Çıkış" />
               </children>
            </VBox>

            <VBox HBox.hgrow="ALWAYS" spacing="14.0"
                  style="-fx-background-color: #F3E3D0;">
               <padding><Insets top="24.0" bottom="24.0" left="24.0" right="24.0" /></padding>
               <children>
                  <Label text="Şikayetler"
                         style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #34495E;" />
                  <HBox spacing="14.0" VBox.vgrow="ALWAYS">
                     <children>
                        <VBox spacing="8.0" prefWidth="320.0">
                           <children>
                              <Label text="Liste" style="-fx-text-fill: #6A7C8F; -fx-font-size: 12px;" />
                              <ListView fx:id="reportList" VBox.vgrow="ALWAYS"
                                        style="-fx-background-color: #EAE0D2;" />
                           </children>
                        </VBox>
                        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label text="Detay" style="-fx-text-fill: #6A7C8F; -fx-font-size: 12px;" />
                              <TextArea fx:id="detailArea" editable="false" wrapText="true" VBox.vgrow="ALWAYS"
                                        style="-fx-control-inner-background: #EAE0D2; -fx-text-fill: #2C3E50;" />
                              <HBox spacing="10.0">
                                 <children>
                                    <Button fx:id="btnRemoveUser" onAction="#removeReportedUser"
                                            styleClass="btn-danger" text="Kullanıcıyı sistemden çıkar" />
                                    <Button fx:id="btnDeletePost" onAction="#deleteReportedPost"
                                            styleClass="btn-danger" text="Blog yazısını sil" />
                                    <Button onAction="#markResolved" styleClass="btn-secondary" text="Şikayeti kapat" />
                                    <Region HBox.hgrow="ALWAYS" />
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</AnchorPane>
