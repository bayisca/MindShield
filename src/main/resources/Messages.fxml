<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="620.0" prefWidth="700.0" styleClass="main-container"
            stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mindshield.ui.MessagesController">
   <children>
      <HBox prefHeight="620.0" prefWidth="700.0"
            AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
            AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>

            <!-- Contacts sidebar -->
            <VBox prefWidth="210.0" spacing="8.0"
                  style="-fx-background-color: #112233; -fx-border-color: transparent #1e3048 transparent transparent; -fx-border-width: 0 1 0 0;">
               <padding><Insets bottom="16.0" left="12.0" right="12.0" top="20.0" /></padding>
               <children>
                  <Label text="Konuşmalar"
                         style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #64748b; -fx-padding: 0 0 8 4;" />
                  <ListView fx:id="contactList" VBox.vgrow="ALWAYS"
                            style="-fx-background-color: transparent; -fx-border-color: transparent;" />
               </children>
            </VBox>

            <!-- Chat area -->
            <VBox HBox.hgrow="ALWAYS" spacing="16.0"
                  style="-fx-background-color: #0d1b2a;">
               <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
               <children>

                  <!-- Header -->
                  <HBox alignment="CENTER_LEFT" spacing="12.0">
                     <children>
                        <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label fx:id="lblSelectedContact"
                                     style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #e2e8f0;"
                                     text="Bir kişi seçin" />
                              <Label text="🔒 Uçtan uca şifreli bağlantı"
                                     style="-fx-font-size: 11px; -fx-text-fill: #22c55e;" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>

                  <Separator />

                  <!-- Chat messages -->
                  <VBox styleClass="card" VBox.vgrow="ALWAYS"
                        style="-fx-padding: 14; -fx-background-radius: 12; -fx-border-radius: 12;">
                     <children>
                        <TextArea fx:id="chatArea" editable="false" wrapText="true" VBox.vgrow="ALWAYS"
                                  style="-fx-background-color: transparent; -fx-control-inner-background: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13; -fx-border-color: transparent; -fx-background-radius: 8;" />
                     </children>
                  </VBox>

                  <!-- Input row -->
                  <HBox spacing="10.0">
                     <children>
                        <TextField fx:id="messageInput" prefHeight="46.0" HBox.hgrow="ALWAYS"
                                   promptText="Mesajınızı yazın..." />
                        <Button onAction="#sendMessage" prefHeight="46.0" prefWidth="90.0" text="Gönder" />
                     </children>
                  </HBox>

               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</AnchorPane>