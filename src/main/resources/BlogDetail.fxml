<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="560.0" prefWidth="680.0" styleClass="main-container"
            stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mindshield.ui.BlogDetailController">
   <children>
      <VBox spacing="14.0"
            AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
            AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <padding><Insets bottom="4.0" left="4.0" right="4.0" top="4.0" /></padding>
         <children>

            <!-- Toolbar -->
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Button fx:id="btnBack" text="Geri Don" styleClass="btn-secondary" />
                  <Button fx:id="btnFavoriteBlog" text="Favorilere ekle" styleClass="btn-secondary" onAction="#handleFavorite" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Button fx:id="btnReport" text="Sikayet et" styleClass="btn-secondary" visible="false" managed="false" />

                  <HBox fx:id="adminControls" spacing="10.0" visible="false">
                     <children>
                        <Button fx:id="btnEdit" text="Duzenle" styleClass="btn-secondary" />
                        <Button fx:id="btnDelete" text="Sil" styleClass="btn-danger" />
                     </children>
                  </HBox>
               </children>
            </HBox>

            <!-- Content card — dark theme -->
            <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
               <content>
                  <VBox spacing="0.0" styleClass="card"
                        style="-fx-background-radius: 14; -fx-border-radius: 14;">
                     <children>

                        <!-- Article header -->
                        <VBox spacing="10.0"
                              style="-fx-background-color: #FAFAFA; -fx-padding: 28 28 18 28;
                                     -fx-background-radius: 14 14 0 0;
                                     -fx-border-color: transparent transparent #D2C4B4 transparent;
                                     -fx-border-width: 0 0 1 0;">
                           <children>
                              <Text fx:id="txtTitle"
                                    style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-fill: #34495E;"
                                    wrappingWidth="580.0" text="Baslik" />
                              <HBox alignment="CENTER_LEFT" spacing="12.0">
                                 <children>
                                    <Label style="-fx-font-size: 12px; -fx-text-fill: #8A9CAE;" text="Yazar:" />
                                    <Label fx:id="lblAuthor"
                                           style="-fx-font-weight: bold; -fx-font-size: 12px;
                                                  -fx-text-fill: #81A6C6;
                                                  -fx-background-color: rgba(129,166,198,0.12);
                                                  -fx-background-radius: 20; -fx-padding: 2 10;" text="—" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label fx:id="lblDate"
                                           style="-fx-font-size: 11px; -fx-text-fill: #8A9CAE;" text="—" />
                                 </children>
                              </HBox>
                           </children>
                        </VBox>

                        <!-- Article body -->
                        <VBox style="-fx-padding: 26 28;">
                           <children>
                              <Text fx:id="txtContent"
                                    style="-fx-font-size: 14px; -fx-fill: #4A5B6C; -fx-line-spacing: 6;"
                                    wrappingWidth="580.0" text="Icerik yukleniyor..." />
                           </children>
                        </VBox>

                        <Separator style="-fx-opacity: 0.3;" />

                        <!-- Comments -->
                        <VBox spacing="14.0" style="-fx-padding: 22 28 28 28;">
                           <children>
                              <Label text="Yorumlar"
                                     style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;" />
                              <VBox fx:id="commentContainer" spacing="10.0" />
                              <HBox spacing="10.0">
                                 <children>
                                    <TextField fx:id="commentInput" prefHeight="42.0"
                                               promptText="Bir yorum yaz..." HBox.hgrow="ALWAYS" />
                                    <Button onAction="#addComment" prefHeight="42.0" text="Gonder" />
                                 </children>
                              </HBox>
                           </children>
                        </VBox>

                     </children>
                  </VBox>
               </content>
            </ScrollPane>

         </children>
      </VBox>
   </children>
</AnchorPane>
